# Example environment variables for Event Review Platform
# Copy to .env and update values for your environment

# Flask settings
FLASK_DEBUG=True
PORT=5000

# Secret key (set a strong value in production)
SECRET_KEY=replace_with_a_strong_secret

# Database URL (Postgres example)
# DATABASE_URL=postgresql://user:password@db:5432/eventdb

# Redis URL for rate limiter (optional)
# RATELIMIT_STORAGE_URL=redis://redis:6379/0

# Optional file storage base path (absolute path) for QR codes and exports
# FILE_STORAGE_PATH=/data/event_platform

# Database connection pool tuning
# DB_POOL_SIZE=10
# DB_MAX_OVERFLOW=20
